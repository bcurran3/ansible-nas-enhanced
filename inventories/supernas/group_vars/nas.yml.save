###
### Watchtower
###
watchtower_enabled: true
watchtower_available_externally: true
watchtower_traefik_whitelist: "{{ lan }}"
# REF - https://containrrr.github.io/watchtower/arguments/
watchtower_cleanup: "true"
watchtower_remove_volumes: "true"
watchtower_debug: "true"
watchtower_include_stopped: "false"
watchtower_revive_stopped: "false"
# watchtower_poll_interval: "0" # "Only schedule or interval can be defined, not both."
watchtower_monitor_only: "false"
watchtower_no_restart: "false"
watchtower_no_pull: "false"
watchtower_schedule: "0 0 5 * * *"
watchtower_timeout: "10"
# REF https://containrrr.github.io/watchtower/notifications/
watchtower_notifications: "gotify" # email, gotify, slack, or msteams
watchtower_notification_email_from: "fromaddress@domain.com"
watchtower_notification_email_to: "{{ ansible_nas_email }}"
watchtower_notification_email_server: "smpt.someserver.com"
watchtower_notification_email_server_tls_skip_verify: "false"
watchtower_notification_email_server_port: "25"
watchtower_notification_email_server_user: "fromaddress@domain.com"
watchtower_notification_email_server_password: "topsecretemailpassword"
watchtower_notification_email_delay: "2"
watchtower_notification_gotify_url: "https://gotify.{{ ansible_nas_domain }}"
watchtower_notification_gotify_token: "A3WOahw5jnEOo_x"
watchtower_notifications_msteams_hook_url: "https://outlook.office.com/webhook/xxxxxxxx@xxxxxxx/IncomingWebhook/yyyyyyy>"
watchtower_notifications_msteams_use_log_data: "true"
watchtower_notifications_slack_hook_url: "https://hooks.slack.com/services/xxx/yyyyyyyyyyyyyyy"
watchtower_notifications_slack_identifier: "{{ ansible_nas_hostname }}"
watchtower_notifications_slack_channel: "#my-custom-channel"
watchtower_notifications_slack_icon_emoji: ":whale:"
watchtower_notifications_slack_icon_url: "http://somewhere.com/icon.png"

