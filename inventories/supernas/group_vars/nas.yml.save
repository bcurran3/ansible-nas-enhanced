# https://github.com/bertvv/ansible-role-samba

samba_shares:
  - name: downloads
    comment: 'Downloaded Stuff'
    guest_ok: no
    public: yes
#    writable: no
    write_list: bill
    browseable: yes
    path: "{{ downloads_root }}"

  - name: movies
    comment: 'Movies'
    guest_ok: yes
    public: yes
    writable: no
    browseable: yes
    path: "{{ movies_root }}"

  - name: tv
    comment: 'TV Episodes'
    guest_ok: yes
    public: yes
    writable: no
    browseable: yes
    path: "{{ tv_root }}"

  - name: music
    comment: 'Music'
    guest_ok: yes
    public: yes
    writable: no
    browseable: yes
    path: "{{ music_root }}"

  - name: dump
    comment: 'File dump'
    guest_ok: yes
    public: yes
    writable: yes
    browseable: yes
#    path: "{{ samba_shares_root }}/dump"
    path: "{{ samba_shares_other_root }}/dump"

  - name: public
    comment: 'Public/Shared'
    guest_ok: yes
    public: yes
    writable: yes
    browseable: yes
#    path: "{{ samba_shares_root }}/public"
    path: "{{ samba_shares_other_root }}/public"

  - name: photos
    comment: 'Pictures'
    guest_ok: yes
    public: yes
    writable: no
    browseable: yes
    path: "{{ photos_root }}"

  - name: books
    comment: 'Books'
    guest_ok: yes
    public: yes
    writable: no
    browseable: yes
    path: "{{ books_root }}"

  - name: audiobooks
    comment: 'Audiobooks'
    guest_ok: yes
    public: yes
    writable: no
    browsable: yes
    path: "{{ audiobooks_root }}"

  - name: comics
    comment: 'Comics'
    guest_ok: yes
    public: yes
    writable: no
    browseable: yes
    path: "{{ comics_root }}"

  - name: games
    comment: 'Games'
    guest_ok: yes
    public: yes
    writable: no
    browseable: yes
    path: "{{ samba_shares_other_root }}/MISC/GAMES"

#  - name: porn
#    comment: 'Stuff downloaded'
#    guest_ok: yes
#    public: yes
#    writable: yes
#    browseable: yes
#    path: "{{ porn_root }}"

  - name: media_root
    comment: 'Media'
    guest_ok: yes
    public: yes
#    writable: yes
    write_list: bill
    browseable: yes
    path: "{{ samba_shares_root }}"

  - name: other_root
    comment: 'Other (non-media)'
    guest_ok: yes
    public: yes
#    writable: yes
    write_list: bill
    browseable: yes
    path: "{{ samba_shares_other_root }}"

  - name: torrents
    comment: 'Torrents'
    guest_ok: yes
    public: yes
    writable: yes
    browseable: yes
    path: "{{ torrents_root }}"

