{
  "mcpServers": {
    "ane-filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/app/server/storage/local"
      ],
      "anythingllm": {
        "autoStart": true,
        "suppressedTools": [
          "read_file",
          "read_media_file"
        ]
      }
    }
  }
}