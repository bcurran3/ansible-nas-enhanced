---
- name: Speedtest Directory
  file:
    path: "{{ item }}"
    state: directory
  with_items:
    - "{{ speedtest_data_directory }}/config"

- name: Speedtest Docker Container
  docker_container:
    name: speedtest
    image: henrywhitaker3/speedtest-tracker:latest
    pull: true
    volumes:
      - "{{ speedtest_data_directory }}/config:/config:rw"
    ports:
      - "{{ speedtest_port_http }}:80"
    dns_servers: "{{ ansible_nas_dns }}"
    hostname: "speedtest"
    env:
      OOKLA_EULA_GDPR: "true"
      TZ: "{{ ansible_nas_timezone }}"
    restart_policy: unless-stopped
    labels:
      traefik.enable: "{{ speedtest_available_externally | string }}"
      traefik.http.middlewares.speedtest.ipwhitelist.sourcerange: "{{ speedtest_traefik_whitelist }}"
      traefik.http.routers.speedtest.rule: "Host(`speedtest.{{ ansible_nas_domain }}`)"
      traefik.http.routers.speedtest.tls.certresolver: "letsencrypt"
      traefik.http.routers.speedtest.tls.domains[0].main: "{{ ansible_nas_domain }}"
      traefik.http.routers.speedtest.tls.domains[0].sans: "*.{{ ansible_nas_domain }}"
      traefik.http.services.speedtest.loadbalancer.server.port: "80"
    memory: 1g
